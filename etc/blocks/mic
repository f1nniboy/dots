#!/bin/sh -e

if wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q "MUTED"; then
	icon="^fg(eba0ac)饇㪽"
else
	icon="^fg(a6e3a1)饇斆"
fi

# get the volume using the generic volume block script
volume=$($XDG_CONFIG_HOME/blocks/volume @DEFAULT_AUDIO_SOURCE@)
echo "^lm(/home/etc/scripts/mute @DEFAULT_AUDIO_SOURCE@)$icon $volume^lm()"
